# Docker Compose Environment Variables
# Copy this file to .env and fill in the actual values

# Database Configuration
# Single-container Docker uses Supabase for the database.
SUPABASE_CONNECTION_STRING=Host=<your-supabase-host>;Port=5432;Database=postgres;Username=postgres.<your-project-ref>;Password=<your-password>;SSL Mode=Require;Trust Server Certificate=true
# Legacy local Postgres keys kept here so the Docker template includes the same database key names as `.env`.
# DB_USER=jobfair_user
# DB_PASSWORD=your_secure_password_here
# DB_NAME=jobfair_db
# DB_HOST=postgres
# DB_PORT=5432

# Backend Configuration
ASPNETCORE_ENVIRONMENT=Production
JWT_SECRET_KEY=your_super_secret_jwt_key_change_this_in_production
Firebase__ServiceAccountPath=/app/backend/config/hirebridge-c28e9-firebase-adminsdk-fbsvc-22c59be5ca.json

# API Configuration
API_BASE_URL=http://api.jfair.local:5158
FRONTEND_URL=http://localhost:3000

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003,http://admin.jfair.local,http://company.jfair.local,http://student.jfair.local

# SMTP Configuration (for email notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@jobfair.com
SMTP_FROM_NAME=Job Fair Portal

# Firebase Configuration (for mobile notifications)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY_ID=your_private_key_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_client_email

# Shared Vite / frontend build configuration (used by company portal and Docker builds)
VITE_BACKEND_URL=http://api.jfair.local:5158
VITE_API_BASE_URL=http://api.jfair.local:5158
VITE_SERVER_URL=http://api.jfair.local:5158
VITE_FIREBASE_API_KEY=your_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_VAPID_KEY=your_fcm_web_vapid_key




# Flutter Web Environment
BACKEND_BASE_URL=http://api.jfair.local:5158

# Security
ALLOWED_FILE_EXTENSIONS=pdf,doc,docx,jpg,jpeg,png
MAX_FILE_SIZE_MB=10

# Feature Flags
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_TWO_FACTOR_AUTH=false
