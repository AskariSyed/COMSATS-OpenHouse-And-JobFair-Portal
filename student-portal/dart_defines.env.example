# ======================================================
# Student Portal (Flutter) – dart-define Variables
# ======================================================
# These are NOT .env files read by Dart/Flutter automatically.
# Pass each variable at build/run time using --dart-define=KEY=VALUE
#
# DEVELOPMENT (local run):
#   flutter run --dart-define=BACKEND_BASE_URL=http://192.168.137.1:5158
#
# PRODUCTION (web build):
#   flutter build web \
#     --dart-define=BACKEND_BASE_URL=https://api.yourdomain.com
#
# PRODUCTION (Android APK release):
#   flutter build apk --release \
#     --dart-define=BACKEND_BASE_URL=https://api.yourdomain.com
#
# Tip: store a full set of dart-defines in a JSON file and use
#   --dart-define-from-file=dart_defines.json  (Flutter >=3.7)
# ======================================================

# Backend base URL (no trailing slash, no /api suffix)
BACKEND_BASE_URL=https://api.yourdomain.com

# Firebase VAPID public key (required for web push notifications)
# Found in: Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
FIREBASE_VAPID_KEY=BF03FtvADQR8PrW4u7iYfaYnZdiU6tsXAxZTPRrVVb9HQ115gpq89FAUmIzp_NFh7PBYO2AW0UbmO-leT5g2V6s
