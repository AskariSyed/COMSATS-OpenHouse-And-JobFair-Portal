# ======================================================
# JobFair Portal – Required Production Environment Variables
# ======================================================
# ASP.NET Core reads these automatically.
# Use double-underscore (__) to represent nested JSON keys.
# e.g.  Jwt__Key  maps to  { "Jwt": { "Key": "..." } }
# ======================================================

# --- Runtime ---
ASPNETCORE_ENVIRONMENT=Production

# --- Database (Supabase PostgreSQL) ---
# Full Npgsql connection string used by Docker and production deployments.
ConnectionStrings__DefaultConnection=Host=<your-supabase-host>;Port=5432;Database=postgres;Username=postgres.<your-project-ref>;Password=<your-password>;SSL Mode=Require;Trust Server Certificate=true

# --- JWT Authentication ---
# At least 32 random bytes, base64-encoded (e.g. openssl rand -base64 32)
Jwt__Key=<your-strong-secret-key>
Jwt__Issuer=RecruitmentApp
Jwt__Audience=RecruitmentAppUsers
Jwt__ExpiryMinutes=120

# --- Firebase Admin SDK ---
# Path to the service-account JSON file inside the container / server
# Mount the file as a secret and point this variable at its path
Firebase__ServiceAccountPath=/run/secrets/firebase-service-account.json

# --- SMTP (Gmail) ---
Smtp__Host=smtp.gmail.com
Smtp__Port=587
Smtp__User=<your-gmail-address>
Smtp__Pass=<your-gmail-app-password>
Smtp__From=<your-gmail-address>

# --- CORS (comma-separated list is NOT supported; set each origin below) ---
# Add every deployed frontend origin that is allowed to call the API.
# Azure / Vercel / Netlify / custom domain examples:
Cors__AllowedOrigins__0=https://admin.yourdomain.com
Cors__AllowedOrigins__1=https://company.yourdomain.com
Cors__AllowedOrigins__2=https://student.yourdomain.com
